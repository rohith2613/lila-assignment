# =============================================================================
# Example .env for the LILA Tic-Tac-Toe frontend.
# Copy this file to `.env` (or `.env.local`) and tweak the values as needed.
#
# Vite exposes any var prefixed with `VITE_` to client code via import.meta.env.
# DO NOT put secrets here — anything in this file is shipped to the browser.
# =============================================================================

# Hostname (no scheme, no port) of the Nakama server. For local dev this is
# `localhost`. For production, set it to your deployed Nakama host (e.g.
# `nakama.example.com`).
VITE_NAKAMA_HOST=localhost

# Port of the Nakama HTTP API. Default Nakama port is 7350.
VITE_NAKAMA_PORT=7350

# Whether to use HTTPS / WSS. Set to `true` when your Nakama server sits
# behind a TLS-terminating reverse proxy (Caddy, nginx, Cloudflare, etc.).
VITE_NAKAMA_USE_SSL=false

# Server key shared between Nakama and the client. Must match the
# `socket.server_key` value in nakama/local.yml. Default Nakama dev key is
# `defaultkey`.
VITE_NAKAMA_SERVER_KEY=defaultkey
